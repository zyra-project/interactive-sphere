*.webm filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text

# App-icon assets predate the LFS catch-all above — they're
# stored in git as regular blobs, not LFS pointers. Without these
# exemptions, the LFS clean filter shows them as endlessly
# "modified" in the working tree (real binary in index, pointer
# in working tree) on every status / checkout. Path overrides
# tell git to treat these as plain binaries, matching how they
# actually live in the repo.
public/*.png            -filter -diff -merge
src-tauri/icons/*.png   -filter -diff -merge
src-tauri/gen/**/*.png  -filter -diff -merge
