# Wrangler local secrets — copy to `.dev.vars` (gitignored) and edit.
#
# Wrangler's `pages dev` reads this file at boot and exposes each
# KEY=value as `env.KEY` inside Pages Functions. Use this template
# as the canonical list of env vars the catalog backend understands.
# Anything not set falls back to the documented default; the
# Functions degrade gracefully when an optional binding is missing.

# --- Node identity (Phase 1a) -------------------------------------
# Generated by `npm run gen:node-key`. Stored as a single base64-DER
# PKCS8 line so wrangler's dotenv parser doesn't need to handle the
# multi-line PEM. Required to advertise the node in
# `/.well-known/terraviz.json`; until federation lands in Phase 4
# the private half is unused.
NODE_ID_PRIVATE_KEY_PEM=

# --- Manifest endpoint --------------------------------------------
# Override the upstream Vimeo proxy that resolves `vimeo:` data_refs.
# Defaults to `https://video-proxy.zyra-project.org/video` when
# unset; tests stub it via a mock fetch.
# VIDEO_PROXY_BASE=

# --- Cloudflare Access (Phase 1a publisher API) -------------------
# Set both for production. The middleware verifies every
# `/api/v1/publish/**` request against this team's JWKS.
# ACCESS_TEAM_DOMAIN=zyra-project.cloudflareaccess.com
# ACCESS_AUD=

# Local-dev shortcut: skip Access entirely and JIT-provision a
# staff publisher keyed off DEV_PUBLISHER_EMAIL. Refused on
# non-loopback hostnames as defense in depth.
DEV_BYPASS_ACCESS=true
DEV_PUBLISHER_EMAIL=dev@localhost

# --- Preview tokens -----------------------------------------------
# HMAC-SHA-256 secret for the publisher-API preview tokens.
# Required in production — the preview endpoints fail closed
# (503 preview_unconfigured) when this is unset.
#
# A deterministic dev fallback exists, but it requires BOTH
# DEV_BYPASS_ACCESS=true AND ALLOW_DEV_PREVIEW_FALLBACK=true to
# activate. The double gate exists because the anonymous preview
# consumer endpoint lives outside the publish middleware that
# refuses dev-bypass on non-loopback hostnames; requiring a
# separate explicit opt-in keeps a production misconfig from
# accepting forged tokens.
# PREVIEW_SIGNING_KEY=
# ALLOW_DEV_PREVIEW_FALLBACK=true

# --- Asset pipeline (Phase 1b) ------------------------------------
# Cloudflare Stream + R2 are the asset-storage backends. Local dev
# defaults to mock mode for both so the contributor walkthrough
# works without a Cloudflare Stream subscription or R2 S3 token.
#
# When MOCK_STREAM=true is set, `mintDirectUploadUrl` returns a
# deterministic `https://mock-stream.localhost/...` URL and
# `getTranscodeStatus` reports 'ready' immediately. The publisher
# API surfaces those upload URLs via /asset; the bytes never
# actually flow anywhere, but every flow downstream — /complete
# digest verification (R2), state-machine transitions, dataset row
# flips — operates on the persisted rows just as in production.
#
# When MOCK_R2=true is set, the asset-init handler returns
# deterministic `https://mock-r2.localhost/...` URLs. Server-side
# digest verification continues to use the CATALOG_R2 binding
# (Wrangler provisions a local on-disk bucket under
# .wrangler/state/v3/r2/ regardless of credentials).
MOCK_STREAM=true
MOCK_R2=true

# Real Stream credentials. Only needed when MOCK_STREAM is unset.
# `STREAM_API_TOKEN` requires the `Stream: Edit` permission.
# `STREAM_CUSTOMER_SUBDOMAIN` is the customer-<id> hostname the
# Stream dashboard prints next to "Customer Subdomain" — used to
# build the public HLS playback URL the manifest endpoint serves.
# STREAM_ACCOUNT_ID=
# STREAM_API_TOKEN=
# STREAM_CUSTOMER_SUBDOMAIN=customer-<id>.cloudflarestream.com

# Real R2 S3 credentials. Only needed when MOCK_R2 is unset.
# `R2_S3_ENDPOINT` is the `https://<account>.r2.cloudflarestorage.com`
# URL the R2 dashboard prints. Cloudflare → R2 → Manage API tokens
# is where access keys are minted. Use a `Read+Write` permission
# scoped to the `terraviz-assets` bucket; presigning runs entirely
# server-side, so the secret only needs to live on the deploy.
# R2_S3_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Bucket name override. Defaults to `terraviz-assets`, matching
# `wrangler.toml`. Only set this if a fork picks a different name.
# CATALOG_R2_BUCKET=terraviz-assets

# Origin used by the sphere-thumbnail pipeline to issue Cloudflare
# Images URL transformations against R2 image sources. When unset,
# the job falls back to fetching the source bytes directly (the
# publisher portal's "regenerate sphere thumbnail" button (Phase 3)
# lets a publisher provide a hand-cropped version manually).
# CF_IMAGES_RESIZE_BASE=https://images.example.com
